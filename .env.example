# Database (required). For local Postgres in Docker: make db-up then use:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/email_auto_agent
DATABASE_URL=postgresql://localhost/email_auto_agent

# Resend (required for sending email)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Default onboarding@resend.dev can only send to your Resend account email or test addresses (e.g. delivered@resend.dev). Verify a domain at https://resend.com/domains to send to any recipient.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional: display name for From (e.g. Goodness). A person-like name can help Gmail put mail in Primary instead of Promotions.
# RESEND_FROM_NAME=Goodness
# Optional: when set and using @resend.dev, redirect all recipients here (e.g. delivered@resend.dev) for local testing
# RESEND_SANDBOX_REDIRECT=delivered@resend.dev
# Optional: reply-to address (e.g. goodness@yourdomain.com). Helps deliverability and Primary placement.
# RESEND_REPLY_TO=goodness@yourdomain.com
#
# --- Gmail Primary vs Promotions ---
# 1. Use your own verified domain (RESEND_FROM_EMAIL=e.g. goodness@klarnow.co.uk) and set RESEND_REPLY_TO to the same or support address.
# 2. Set RESEND_FROM_NAME to a person-like name (e.g. Goodness) so From shows "Goodness <goodness@...>" — can help Primary.
# 3. Avoid promo-style subject lines and heavy marketing copy; engagement (opens/replies) and list quality also affect tab placement.

# TRACKING_BASE_URL: used for open/click tracking links and for campaign image URLs so images load in emails. Must be reachable by recipients (use your public API URL in production, e.g. https://api.yourdomain.com).
# TRACKING_BASE_URL=http://localhost:8000
# Secret for signing tracking URLs; set in production to prevent fake open/click events
# TRACKING_SECRET=change-me-in-production

# WhatsApp (Twilio) — for campaigns with channel=whatsapp
# TWILIO_ACCOUNT_SID=ACxxxx
# TWILIO_AUTH_TOKEN=xxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional
PORT=8000
CORS_ORIGINS=http://localhost:3000
SERVE_STATIC=true

# Frontend (in frontend/.env or passed at build): API base for fetch calls.
# - Local dev (frontend on 3000, backend on 8000): NEXT_PUBLIC_API_URL=http://localhost:8000
# - Production (same host serves both): NEXT_PUBLIC_API_URL="" or unset (Dockerfile sets this)
